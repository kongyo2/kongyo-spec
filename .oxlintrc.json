{
  "plugins": ["typescript", "import", "promise", "node"],
  "categories": {
    "correctness": "error",
    "suspicious": "warn",
    "perf": "warn",
    "style": "off",
    "pedantic": "off"
  },
  "rules": {
    "no-console": "off",
    "no-underscore-dangle": ["warn", { "allow": ["__APP_VERSION__"] }],
    "promise/always-return": ["warn", { "ignoreLastCallback": true }],
    "import/no-unassigned-import": ["warn", { "allow": ["**/*.css"] }]
  },
  "ignorePatterns": ["node_modules", "dist", "build", "coverage", "out", "release", "*.min.js"]
}
