{
  "name": "kongyo-spec",
  "version": "0.1.0",
  "description": "Desktop markdown spec editor for AI-driven development. MDXG-conforming: virtual pages, GFM, shiki, mermaid, KaTeX.",
  "author": "kongyo2",
  "license": "MIT",
  "main": "./out/main/index.js",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "preview": "electron-vite preview",
    "typecheck": "tsc --noEmit -p tsconfig.node.json && tsc --noEmit -p tsconfig.json",
    "typecheck:watch": "tsc --noEmit -p tsconfig.json --watch",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "lint": "oxlint --format agent",
    "lint:fix": "oxlint --fix",
    "lint:strict": "oxlint --deny-warnings",
    "lint:ci": "oxlint --format github"
  },
  "dependencies": {
    "@shikijs/rehype": "^4.2.0",
    "github-slugger": "^2.0.0",
    "hast-util-to-text": "^4.0.2",
    "katex": "^0.17.0",
    "mdast-util-to-string": "^4.0.0",
    "mermaid": "^11.15.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "rehype-autolink-headings": "^7.1.0",
    "rehype-katex": "^7.0.1",
    "rehype-raw": "^7.0.0",
    "rehype-stringify": "^10.0.1",
    "remark-gfm": "^4.0.1",
    "remark-math": "^6.0.0",
    "remark-parse": "^11.0.0",
    "remark-rehype": "^11.1.2",
    "shiki": "^4.2.0",
    "unified": "^11.0.5",
    "unist-util-visit": "^5.1.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/katex": "^0.16.8",
    "@types/node": "^25.9.2",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.2.0",
    "electron": "^42.3.3",
    "electron-vite": "^5.0.0",
    "oxlint": "^1.68.0",
    "prettier": "^3.8.3",
    "typescript": "^6.0.3",
    "vite": "^7.3.5"
  }
}
